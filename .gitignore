# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/test-results/
/playwright/.cache/

# env example은 커밋, 실제 환경값은 무시 (아래 .env* 패턴이 그대로 유효)
!.env.example

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel
# project.json은 projectId/orgId만 들고 있어 비밀이 아님 — CD workflow에서 필요
!.vercel/project.json

# typescript
*.tsbuildinfo
next-env.d.ts

#env
env.*